# Hidden upstream services (private domains). Needed by nginx and by the nuxt container (GET /api/verify-registration).
DIRECTUS_UPSTREAM=https://directus.dginozator.com
N8N_UPSTREAM=https://n8n.dginozator.com

# Public prefixes used by frontend
NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_DIRECTUS_BASE=/api/d
NUXT_PUBLIC_N8N_BASE=/api/n
# Optional explicit reset page URL used in Directus reset emails.
# If empty, frontend uses <current-origin>/reset-password.
NUXT_PUBLIC_DIRECTUS_RESET_URL=
# Canonical verify-email URL for registration mail. If empty, uses <browser-origin>/verify-email.
# Production example: NUXT_PUBLIC_DIRECTUS_VERIFY_URL=https://wb.dginozator.com/verify-email
NUXT_PUBLIC_DIRECTUS_VERIFY_URL=
