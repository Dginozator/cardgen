# Скопируйте в ".env" и заполните. Файл .env в git не коммитится.

# Обязательно:
ROUTERAI_API_KEY=

# Опционально (можно удалить строки — будут значения по умолчанию):
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
CARDGEN_CHAT_MODEL=openai/gpt-5.4
CARDGEN_IMAGE_MODEL=google/gemini-2.5-flash-image

# Каталог логов (cardgen.log, prompts.log). По умолчанию data/logs
# CARDGEN_LOG_DIR=data/logs
