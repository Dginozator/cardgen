# Скопируйте в ".env" и заполните. Файл .env в git не коммитится.

# Обязательно:
ROUTERAI_API_KEY=

# Опционально (можно удалить строки — будут значения по умолчанию):
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
CARDGEN_CHAT_MODEL=openai/gpt-5.4
CARDGEN_IMAGE_MODEL=google/gemini-2.5-flash-image

# Каталог логов (cardgen.log, prompts.log). По умолчанию data/logs
# CARDGEN_LOG_DIR=data/logs

# Dokploy / reverse proxy settings for directus_gen flow
APP_DOMAIN=app.example.com
APP_PORT=8080

# Hidden upstream services (private domains)
DIRECTUS_UPSTREAM=https://directus.dginozator.com
N8N_UPSTREAM=https://n8n.dginozator.com

# Public prefixes used by frontend
NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_DIRECTUS_BASE=/api/d
NUXT_PUBLIC_N8N_BASE=/api/n
